generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(EMPLOYEE)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  icon      String?
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Supplier {
  id        String            @id @default(cuid())
  name      String
  phone     String?
  address   String?
  email     String?
  notes     String?
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  products  ProductSupplier[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  createdAt DateTime @default(now())
  models    Model[]
}

model Model {
  id            String         @id @default(cuid())
  name          String
  brandId       String
  createdAt     DateTime       @default(now())
  brand         Brand          @relation(fields: [brandId], references: [id])
  productModels ProductModel[]

  @@unique([brandId, name])
}

model Product {
  id                     String            @id @default(cuid())
  name                   String
  subname                String?
  description            String?
  brand                  String?
  categoryId             String
  isModalProduct         Boolean           @default(false)
  quickAddIncrement      Int?
  price                  Float
  specialPrice           Float?
  specialQuantity        Int?
  superWholesalePrice    Float?
  superWholesaleQuantity Int?
  cost                   Float?
  boxQuantity            Int?
  isActive               Boolean           @default(true)
  featured               Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  kitProducts            KitProduct[]
  orderItems             OrderItem[]
  category               Category          @relation(fields: [categoryId], references: [id])
  images                 ProductImage[]
  models                 ProductModel[]
  suppliers              ProductSupplier[]
}

model ProductImage {
  id                 String    @id @default(cuid())
  productId          String
  url                String
  fileName           String?
  order              Int       @default(0)
  isMain             Boolean   @default(false)
  createdAt          DateTime  @default(now())
  cloudinaryPublicId String?
  fileSize           Int?
  height             Int?
  lastViewedAt       DateTime?
  normalUrl          String?
  thumbnailUrl       String?
  updatedAt          DateTime  @default(now()) @updatedAt
  viewCount          Int       @default(0)
  width              Int?
  product            Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductSupplier {
  id         String   @id @default(cuid())
  productId  String
  supplierId String
  cost       Float
  isActive   Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product  @relation(fields: [productId], references: [id])
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  @@unique([productId, supplierId])
}

model ProductModel {
  id                  String   @id @default(cuid())
  productId           String
  modelId             String
  price               Float?
  superWholesalePrice Float?
  createdAt           DateTime @default(now())
  model               Model    @relation(fields: [modelId], references: [id])
  product             Product  @relation(fields: [productId], references: [id])

  @@unique([productId, modelId])
}

model Kit {
  id          String       @id @default(cuid())
  name        String       @unique
  description String
  discount    Float
  image       String?
  order       Int          @default(0)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  products    KitProduct[]
}

model KitProduct {
  id        String   @id @default(cuid())
  kitId     String
  productId String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  kit       Kit      @relation(fields: [kitId], references: [id])
  product   Product  @relation(fields: [productId], references: [id])

  @@unique([kitId, productId])
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  whatsapp    String   @unique
  email       String?
  company     String?
  cnpj        String?
  firstAccess DateTime @default(now())
  lastAccess  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  customerId     String
  subtotal       Float
  discount       Float        @default(0)
  total          Float
  status         OrderStatus  @default(PENDING)
  assignedSeller String?
  notes          String?
  internalNotes  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  confirmedAt    DateTime?
  completedAt    DateTime?
  customer       Customer     @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  webhookLogs    WebhookLog[]
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String
  modelName   String?
  quantity    Int
  unitPrice   Float
  totalPrice  Float
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model CompanySettings {
  id            String   @id @default(cuid())
  companyName   String
  tradeName     String?
  cnpj          String?
  logo          String?
  primaryColor  String   @default("#FC6D36")
  phone         String?
  whatsapp      String?
  email         String?
  address       String?
  instagram     String?
  facebook      String?
  privacyPolicy String?
  termsOfUse    String?
  aboutUs       String?
  minOrderValue Float?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model WebhookLog {
  id           String           @id @default(cuid())
  eventType    WebhookEventType
  orderId      String?
  payload      Json
  response     Json?
  statusCode   Int?
  success      Boolean          @default(false)
  errorMessage String?
  createdAt    DateTime         @default(now())
  order        Order?           @relation(fields: [orderId], references: [id])
}

model Session {
  id           String    @id @default(cuid())
  whatsapp     String?
  unlocked     Boolean   @default(false)
  unlockedAt   DateTime?
  lastActivity DateTime  @default(now())
  cartData     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ShippingCompany {
  id        String   @id @default(cuid())
  name      String   @unique
  logo      String?
  isActive  Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum OrderStatus {
  PENDING
  PROCESSING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum WebhookEventType {
  PRICE_UNLOCK
  ORDER_CREATED
  ORDER_UPDATED
  CART_ABANDONED
  PRODUCT_SEARCH
  PRODUCT_VIEW
  CATEGORY_VIEW
}
